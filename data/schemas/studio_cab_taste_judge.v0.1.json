{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oseria.local/schemas/deadman/studio_cab_taste_judge.v0.1.json",
  "title": "Deadman Studio CAB Taste Judge v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product",
    "created_at",
    "status",
    "claim_boundary",
    "provider_identity_redacted",
    "proof_ref",
    "planned_case_count",
    "attempted_case_count",
    "completed_case_count",
    "verdicts",
    "verdict_summary"
  ],
  "properties": {
    "schema_version": { "const": "studio_cab_taste_judge.v0.1" },
    "product": { "const": "看剧搭子" },
    "created_at": { "type": "string", "minLength": 1 },
    "status": { "enum": ["completed", "completed_with_failures", "provider_blocked"] },
    "claim_boundary": { "type": "string", "minLength": 1 },
    "provider_identity_redacted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model_alias", "mock_provider", "role"],
      "properties": {
        "provider": { "enum": ["ark", "bailian"] },
        "model_alias": { "type": "string", "minLength": 1 },
        "mock_provider": { "const": false },
        "role": { "const": "taste_judge" }
      }
    },
    "proof_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "schema_version"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "schema_version": { "const": "studio_cab_real_provider_proof.v0.1" }
      }
    },
    "planned_case_count": { "type": "integer", "minimum": 0 },
    "attempted_case_count": { "type": "integer", "minimum": 0 },
    "completed_case_count": { "type": "integer", "minimum": 0 },
    "verdicts": {
      "type": "array",
      "items": { "$ref": "#/$defs/verdict" }
    },
    "verdict_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accept", "accept_with_minor_tweak", "reject", "provider_failed_or_invalid"],
      "properties": {
        "accept": { "type": "integer", "minimum": 0 },
        "accept_with_minor_tweak": { "type": "integer", "minimum": 0 },
        "reject": { "type": "integer", "minimum": 0 },
        "provider_failed_or_invalid": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "case_type",
        "item_id",
        "episode_id",
        "provider_status",
        "provider_status_class",
        "latency_bucket",
        "token_usage",
        "schema_validation",
        "lead_taste",
        "reply_voice_taste",
        "reply_axis_diversity",
        "echo_taste",
        "overall_verdict",
        "rationale_summary",
        "prompt_hash"
      ],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "case_type": {
          "enum": [
            "owner_gold_exchange_authoring",
            "phase2_repair_regression"
          ]
        },
        "item_id": { "type": "string", "minLength": 1 },
        "episode_id": { "type": "string", "pattern": "^huangnian_ep[0-9]{2}$" },
        "provider_status": { "enum": ["completed", "provider_failed", "schema_invalid"] },
        "provider_status_class": { "enum": ["success", "provider_error", "schema_error"] },
        "latency_bucket": { "enum": ["not_available", "lt_5s", "lt_15s", "lt_30s", "gte_30s"] },
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_tokens", "output_tokens", "total_tokens"],
          "properties": {
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens": { "type": "integer", "minimum": 0 }
          }
        },
        "schema_validation": { "enum": ["pass", "fail"] },
        "lead_taste": { "enum": ["excellent", "acceptable", "needs_repair", "not_available"] },
        "reply_voice_taste": { "enum": ["excellent", "acceptable", "needs_repair", "not_available"] },
        "reply_axis_diversity": { "enum": ["excellent", "acceptable", "needs_repair", "not_available"] },
        "echo_taste": { "enum": ["excellent", "acceptable", "needs_repair", "not_available"] },
        "overall_verdict": {
          "enum": [
            "accept",
            "accept_with_minor_tweak",
            "reject",
            "not_available"
          ]
        },
        "rationale_summary": { "type": "string" },
        "prompt_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
