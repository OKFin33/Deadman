{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oseria.local/schemas/deadman/studio_cab_guidance_dataset.v0.1.json",
  "title": "Deadman Studio CAB Guidance Dataset v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product",
    "created_at",
    "status",
    "claim_boundary",
    "source_artifacts",
    "contracts",
    "agent_native_definition",
    "provenance_policy",
    "summary",
    "splits",
    "real_provider_proof_plan"
  ],
  "properties": {
    "schema_version": {
      "const": "studio_cab_guidance_dataset.v0.1"
    },
    "product": {
      "const": "看剧搭子"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["pre_real_provider_proof_ready", "owner_reviewed_v1_frozen"]
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 1
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_artifact"
      }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "agent_native_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_contract",
        "evaluation_benchmark",
        "knowledge_boundary",
        "authoring_proof_substrate",
        "product_taste_guardrail"
      ],
      "properties": {
        "runtime_contract": {
          "type": "string",
          "minLength": 1
        },
        "evaluation_benchmark": {
          "type": "string",
          "minLength": 1
        },
        "knowledge_boundary": {
          "type": "string",
          "minLength": 1
        },
        "authoring_proof_substrate": {
          "type": "string",
          "minLength": 1
        },
        "product_taste_guardrail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_values",
        "owner_truth_values",
        "non_owner_truth_values",
        "rule"
      ],
      "properties": {
        "allowed_values": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/provenance"
          }
        },
        "owner_truth_values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/provenance"
          }
        },
        "non_owner_truth_values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/provenance"
          }
        },
        "rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_gold_examples",
        "window_negative_examples",
        "owner_reviewed_window_negative_or_context_examples",
        "lead_examples",
        "lead_rejected_examples",
        "lead_repair_examples",
        "reply_examples",
        "reply_rejected_examples",
        "reply_repair_examples",
        "runtime_reviewed_selected_echo_examples",
        "owner_reviewed_selected_echo_examples",
        "draft_selected_echo_examples",
        "real_provider_proof_cases_planned"
      ],
      "properties": {
        "window_gold_examples": {
          "type": "integer",
          "minimum": 1
        },
        "window_negative_examples": {
          "type": "integer",
          "minimum": 1
        },
        "owner_reviewed_window_negative_or_context_examples": {
          "type": "integer",
          "minimum": 1
        },
        "lead_examples": {
          "type": "integer",
          "minimum": 1
        },
        "lead_rejected_examples": {
          "type": "integer",
          "minimum": 0
        },
        "lead_repair_examples": {
          "type": "integer",
          "minimum": 0
        },
        "reply_examples": {
          "type": "integer",
          "minimum": 1
        },
        "reply_rejected_examples": {
          "type": "integer",
          "minimum": 0
        },
        "reply_repair_examples": {
          "type": "integer",
          "minimum": 0
        },
        "runtime_reviewed_selected_echo_examples": {
          "type": "integer",
          "minimum": 1
        },
        "owner_reviewed_selected_echo_examples": {
          "type": "integer",
          "minimum": 0
        },
        "draft_selected_echo_examples": {
          "type": "integer",
          "minimum": 1
        },
        "real_provider_proof_cases_planned": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "splits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_selection",
        "context_card_requirements",
        "lead_authoring",
        "reply_authoring",
        "selected_echo_direction",
        "custom_input_policy",
        "release_gate_rules"
      ],
      "properties": {
        "window_selection": {
          "$ref": "#/$defs/split"
        },
        "context_card_requirements": {
          "$ref": "#/$defs/split"
        },
        "lead_authoring": {
          "$ref": "#/$defs/split"
        },
        "reply_authoring": {
          "$ref": "#/$defs/split"
        },
        "selected_echo_direction": {
          "$ref": "#/$defs/split"
        },
        "custom_input_policy": {
          "$ref": "#/$defs/split"
        },
        "release_gate_rules": {
          "$ref": "#/$defs/split"
        }
      }
    },
    "real_provider_proof_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "provider_invocation",
        "requires_env",
        "tracked_output_when_run",
        "raw_trace_policy",
        "sample_policy",
        "planned_cases"
      ],
      "properties": {
        "status": {
          "const": "prepared_not_run"
        },
        "provider_invocation": {
          "const": "not_started"
        },
        "requires_env": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tracked_output_when_run": {
          "const": "data/evals/studio_cab_real_provider_proof.v0.1.json"
        },
        "raw_trace_policy": {
          "type": "string",
          "minLength": 1
        },
        "sample_policy": {
          "type": "string",
          "minLength": 1
        },
        "planned_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/proof_case"
          }
        }
      }
    }
  },
  "$defs": {
    "source_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "schema_version"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "schema_version": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "enum": [
        "owner_confirmed",
        "owner_reviewed_reject",
        "owner_context_insufficient",
        "agent_labeled_negative",
        "phase2_repair",
        "runtime_reviewed",
        "draft_not_owner_reviewed"
      ]
    },
    "split": {
      "type": "object"
    },
    "proof_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "case_type",
        "item_id",
        "episode_id",
        "expected_behavior",
        "provenance"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "case_type": {
          "enum": [
            "owner_gold_exchange_authoring",
            "owner_reviewed_window_reject",
            "phase2_repair_regression"
          ]
        },
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "episode_id": {
          "type": "string",
          "pattern": "^huangnian_ep[0-9]{2}$"
        },
        "expected_behavior": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    }
  }
}
