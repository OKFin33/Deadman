{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oseria.local/schemas/deadman/studio_cab_real_provider_proof.v0.1.json",
  "title": "Deadman Studio CAB Real Provider Proof v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product",
    "created_at",
    "status",
    "claim_boundary",
    "provider_identity_redacted",
    "guidance_dataset_ref",
    "planned_case_count",
    "attempted_case_count",
    "completed_case_count",
    "publication_decision",
    "case_results",
    "failure_buckets",
    "repair_candidates"
  ],
  "properties": {
    "schema_version": {
      "const": "studio_cab_real_provider_proof.v0.1"
    },
    "product": {
      "const": "看剧搭子"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["completed", "completed_with_failures", "provider_blocked"]
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 1
    },
    "provider_identity_redacted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model_alias", "mock_provider"],
      "properties": {
        "provider": {
          "enum": ["ark"]
        },
        "model_alias": {
          "type": "string",
          "minLength": 1
        },
        "mock_provider": {
          "const": false
        }
      }
    },
    "guidance_dataset_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "schema_version", "created_at"],
      "properties": {
        "path": {
          "const": "data/datasets/studio_guidance/studio_cab_guidance_dataset.v0.1.json"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "schema_version": {
          "const": "studio_cab_guidance_dataset.v0.1"
        },
        "created_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "planned_case_count": {
      "type": "integer",
      "minimum": 1
    },
    "attempted_case_count": {
      "type": "integer",
      "minimum": 0
    },
    "completed_case_count": {
      "type": "integer",
      "minimum": 0
    },
    "publication_decision": {
      "const": "no_runtime_promotion"
    },
    "case_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/case_result"
      }
    },
    "failure_buckets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure_bucket"
      }
    },
    "repair_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repair_candidate"
      }
    }
  },
  "$defs": {
    "case_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "case_type",
        "item_id",
        "episode_id",
        "provenance",
        "expected_behavior",
        "provider_status",
        "provider_status_class",
        "latency_bucket",
        "token_usage",
        "schema_validation",
        "conformance_validation",
        "draft_review_status",
        "window_decision",
        "failure_buckets",
        "draft",
        "rationale_summary",
        "repair_notes",
        "prompt_hash"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "case_type": {
          "enum": [
            "owner_gold_exchange_authoring",
            "owner_reviewed_window_reject",
            "phase2_repair_regression"
          ]
        },
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "episode_id": {
          "type": "string",
          "pattern": "^huangnian_ep[0-9]{2}$"
        },
        "provenance": {
          "enum": [
            "owner_confirmed",
            "owner_reviewed_reject",
            "owner_context_insufficient",
            "phase2_repair"
          ]
        },
        "expected_behavior": {
          "type": "string",
          "minLength": 1
        },
        "provider_status": {
          "enum": ["completed", "provider_failed", "schema_invalid"]
        },
        "provider_status_class": {
          "enum": ["success", "provider_error", "schema_error"]
        },
        "latency_bucket": {
          "enum": ["not_available", "lt_5s", "lt_15s", "lt_30s", "gte_30s"]
        },
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_tokens", "output_tokens", "total_tokens"],
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "total_tokens": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "schema_validation": {
          "enum": ["pass", "fail"]
        },
        "conformance_validation": {
          "enum": ["pass", "fail"]
        },
        "draft_review_status": {
          "const": "draft_not_owner_reviewed"
        },
        "window_decision": {
          "enum": ["recommend_window", "reject_window", "needs_context", "needs_owner_review", "not_available"]
        },
        "failure_buckets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure_id"
          }
        },
        "draft": {
          "type": "object",
          "additionalProperties": false,
          "required": ["companion_lead", "reply_candidates"],
          "properties": {
            "companion_lead": {
              "type": "string"
            },
            "reply_candidates": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/reply_candidate"
              }
            }
          }
        },
        "rationale_summary": {
          "type": "string"
        },
        "repair_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prompt_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "reply_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_text", "emotion_role", "semantic_role", "viewer_motivation", "selected_echo"],
      "properties": {
        "display_text": {
          "type": "string"
        },
        "emotion_role": {
          "type": "string"
        },
        "semantic_role": {
          "type": "string"
        },
        "viewer_motivation": {
          "type": "string"
        },
        "selected_echo": {
          "type": "string"
        }
      }
    },
    "failure_bucket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucket", "count", "case_ids"],
      "properties": {
        "bucket": {
          "$ref": "#/$defs/failure_id"
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "case_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "repair_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repair_id",
        "case_id",
        "item_id",
        "episode_id",
        "failure_bucket",
        "field",
        "problem",
        "suggested_repair_seed",
        "provenance"
      ],
      "properties": {
        "repair_id": {
          "type": "string",
          "minLength": 1
        },
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "episode_id": {
          "type": "string",
          "pattern": "^huangnian_ep[0-9]{2}$"
        },
        "failure_bucket": {
          "$ref": "#/$defs/failure_id"
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "suggested_repair_seed": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "const": "real_provider_proof"
        }
      }
    },
    "failure_id": {
      "enum": [
        "reviewable_without_major_rewrite",
        "reviewable_with_minor_repair",
        "needs_owner_taste_review",
        "expected_rejection_pass",
        "context_boundary_pass",
        "repair_regression_pass",
        "wrong_window",
        "wrong_lead_shape",
        "wrong_reply_shape",
        "wrong_echo_shape",
        "insufficient_context_detected",
        "unsupported_claim",
        "future_branch_claim",
        "rpg_or_action_menu_regression",
        "echo_paraphrases_display_text",
        "echo_formulaic_prefix_repetition",
        "echo_disconnected_from_display_text",
        "echo_too_long",
        "display_text_reused_from_rejected_round",
        "provider_or_schema_failure"
      ]
    }
  }
}
