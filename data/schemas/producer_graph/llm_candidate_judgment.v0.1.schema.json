{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oseria.local/deadman/producer_graph/llm_candidate_judgment.v0.1.schema.json",
  "title": "Deadman Studio LLM Candidate Judgment v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task",
    "run_id",
    "drama_id",
    "drama_title",
    "provider",
    "source_candidate_ref",
    "input_candidate_count",
    "shortlist_policy",
    "judgment_count",
    "decisions_summary",
    "judgments"
  ],
  "properties": {
    "schema_version": {
      "const": "deadman_llm_candidate_judgment.v0.1"
    },
    "task": {
      "const": "llm_candidate_judge"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "drama_id": {
      "type": "string",
      "minLength": 1
    },
    "drama_title": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model",
        "mock_provider",
        "latency_ms",
        "token_usage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "mock_provider": {
          "type": "boolean"
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input_tokens",
            "output_tokens",
            "total_tokens"
          ],
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "total_tokens": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "source_candidate_ref": {
      "type": "string",
      "minLength": 1
    },
    "input_candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "shortlist_policy": {
      "type": "object"
    },
    "judgment_count": {
      "type": "integer",
      "minimum": 0
    },
    "decisions_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommend",
        "keep_for_review",
        "reject"
      ],
      "properties": {
        "recommend": {
          "type": "integer",
          "minimum": 0
        },
        "keep_for_review": {
          "type": "integer",
          "minimum": 0
        },
        "reject": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "judgments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "decision",
          "confidence",
          "rationale",
          "failure_modes",
          "source_refs"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "enum": [
              "recommend",
              "keep_for_review",
              "reject"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "failure_modes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_refs": {
            "type": "object"
          }
        }
      }
    }
  }
}
