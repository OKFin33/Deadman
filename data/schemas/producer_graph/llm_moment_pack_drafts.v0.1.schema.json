{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oseria.local/deadman/producer_graph/llm_moment_pack_drafts.v0.1.schema.json",
  "title": "Deadman Studio LLM Moment Pack Drafts v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task",
    "run_id",
    "drama_id",
    "drama_title",
    "provider",
    "source_refs",
    "draft_count",
    "moment_drafts"
  ],
  "properties": {
    "schema_version": {
      "const": "deadman_llm_moment_pack_drafts.v0.1"
    },
    "task": {
      "const": "llm_moment_pack_draft"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "drama_id": {
      "type": "string",
      "minLength": 1
    },
    "drama_title": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "draft_count": {
      "type": "integer",
      "minimum": 0
    },
    "moment_drafts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "draft_moment_id",
          "hook_draft",
          "viewer_impulse_draft",
          "mouthpiece_candidate_drafts",
          "actor_context_draft",
          "local_constraints_draft",
          "canon_baseline_draft",
          "judgment_basis_draft",
          "visual_result_policy_draft",
          "inference_level",
          "requires_human_review",
          "source_refs"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "draft_moment_id": {
            "type": "string",
            "minLength": 1
          },
          "hook_draft": {
            "type": "string",
            "minLength": 1
          },
          "viewer_impulse_draft": {
            "type": "string",
            "minLength": 1
          },
          "preset_action_drafts": {
            "description": "Legacy v0.3 action-menu draft list. Keep only for compatibility.",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mouthpiece_candidate_drafts": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "items": {
              "$ref": "#/$defs/mouthpiece_candidate_draft"
            }
          },
          "actor_context_draft": {
            "type": "string",
            "minLength": 1
          },
          "local_constraints_draft": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "canon_baseline_draft": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "original_action",
              "original_rationale",
              "audience_tension"
            ],
            "properties": {
              "original_action": {
                "type": "string",
                "minLength": 1
              },
              "original_rationale": {
                "type": "string",
                "minLength": 1
              },
              "audience_tension": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "judgment_basis_draft": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "visual_result_policy_draft": {
            "type": "string",
            "minLength": 1
          },
          "inference_level": {
            "enum": [
              "source_supported",
              "model_inferred",
              "human_review_required"
            ]
          },
          "requires_human_review": {
            "const": true
          },
          "source_refs": {
            "type": "object"
          }
        }
      }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model",
        "mock_provider",
        "latency_ms",
        "token_usage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "mock_provider": {
          "type": "boolean"
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input_tokens",
            "output_tokens",
            "total_tokens"
          ],
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "total_tokens": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "mouthpiece_candidate_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "display_text",
        "action_payload",
        "selected_echo",
        "emotion_role",
        "semantic_role",
        "distinctness_rationale",
        "evidence_refs",
        "constraint_refs",
        "requires_human_review"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "display_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 14
        },
        "action_payload": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "text"
          ],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            },
            "action_type": {
              "type": "string"
            },
            "intent": {
              "type": "string"
            },
            "target_actors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "risk_posture": {
              "type": "string"
            }
          }
        },
        "emotion_role": {
          "type": "string",
          "minLength": 1
        },
        "semantic_role": {
          "type": "string",
          "minLength": 1
        },
        "distinctness_rationale": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "constraint_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selected_echo": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "friend_voice_seed": {
          "type": "string"
        },
        "requires_human_review": {
          "const": true
        }
      }
    }
  }
}
