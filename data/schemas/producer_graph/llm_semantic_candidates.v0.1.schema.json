{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oseria.local/deadman/producer_graph/llm_semantic_candidates.v0.1.schema.json",
  "title": "Deadman Studio LLM Semantic Candidates v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task",
    "run_id",
    "drama_id",
    "drama_title",
    "provider",
    "source_refs",
    "candidate_count",
    "candidates"
  ],
  "properties": {
    "schema_version": {
      "const": "deadman_llm_semantic_candidates.v0.1"
    },
    "task": {
      "const": "llm_semantic_miner"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "drama_id": {
      "type": "string",
      "minLength": 1
    },
    "drama_title": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "semantic_candidate_id",
          "origin",
          "linked_candidate_id",
          "episode_id",
          "window_id",
          "time_range_ms",
          "hook",
          "viewer_impulse",
          "intervention_logic",
          "evidence_excerpt",
          "uncertainty",
          "confidence",
          "field_signals",
          "suggested_options",
          "source_refs",
          "failure_modes"
        ],
        "properties": {
          "semantic_candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "origin": {
            "enum": [
              "deterministic_enriched",
              "llm_discovered"
            ]
          },
          "linked_candidate_id": {
            "type": "string"
          },
          "episode_id": {
            "type": "string",
            "minLength": 1
          },
          "window_id": {
            "type": "string",
            "minLength": 1
          },
          "time_range_ms": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "integer",
              "minimum": 0
            }
          },
          "hook": {
            "type": "string",
            "minLength": 1
          },
          "viewer_impulse": {
            "type": "string",
            "minLength": 1
          },
          "intervention_logic": {
            "type": "string",
            "minLength": 1
          },
          "evidence_excerpt": {
            "type": "string",
            "minLength": 1
          },
          "uncertainty": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "field_signals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "suggested_options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_refs": {
            "type": "object"
          },
          "failure_modes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model",
        "mock_provider",
        "latency_ms",
        "token_usage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "mock_provider": {
          "type": "boolean"
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input_tokens",
            "output_tokens",
            "total_tokens"
          ],
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "total_tokens": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
