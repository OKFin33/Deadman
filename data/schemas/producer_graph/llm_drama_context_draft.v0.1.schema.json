{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oseria.local/deadman/producer_graph/llm_drama_context_draft.v0.1.schema.json",
  "title": "Deadman Studio LLM Drama Context Draft v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task",
    "run_id",
    "drama_id",
    "drama_title",
    "provider",
    "source_refs",
    "context_draft",
    "uncertainty_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "deadman_llm_drama_context_draft.v0.1"
    },
    "task": {
      "const": "llm_drama_context_draft"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "drama_id": {
      "type": "string",
      "minLength": 1
    },
    "drama_title": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "context_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "premise_draft",
        "genre_contract_draft",
        "protagonist_draft",
        "core_constraints_draft",
        "relationship_drafts",
        "guardrails",
        "open_questions"
      ],
      "properties": {
        "premise_draft": {
          "type": "string",
          "minLength": 1
        },
        "genre_contract_draft": {
          "type": "string",
          "minLength": 1
        },
        "protagonist_draft": {
          "type": "string",
          "minLength": 1
        },
        "core_constraints_draft": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/draft_item"
          }
        },
        "relationship_drafts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/draft_item"
          }
        },
        "guardrails": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "uncertainty_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model",
        "mock_provider",
        "latency_ms",
        "token_usage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "mock_provider": {
          "type": "boolean"
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input_tokens",
            "output_tokens",
            "total_tokens"
          ],
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "total_tokens": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "draft_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "value",
        "confidence",
        "inference_level",
        "source_refs"
      ],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "inference_level": {
          "enum": [
            "source_supported",
            "model_inferred",
            "human_review_required"
          ]
        },
        "source_refs": {
          "type": "object"
        }
      }
    }
  }
}
