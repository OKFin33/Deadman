# 看剧搭子 (Deadman) — environment template.
# Copy to .env and fill in:  cp .env.example .env
# ALL credentials are environment-only and producer-side (used only when the team
# authors content). Never commit real values (.env is gitignored).
#
# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 观众端默认互动（开场 + 三句「我想说」+ 回声）来自已审核 pack，零 key、播放不调模型。│
# │ 需要 key 的是：① 观众端【自定义输入】（说自己的话→搭子接话，观众体验一等能力）     │
# │               ② 制作端 Studio 实时创作 / 上传 ASR。                              │
# └──────────────────────────────────────────────────────────────────────────────┘

# 三类模型——已给预设、开箱即用，也可替换（换 key / 换模型）：
#   1) 创作 + 语义选窗 = Ark / Doubao（ARK_*，默认 Doubao-Seed-2.0-lite）
#   2) ASR 语音转写     = 豆包 / 火山语音（DOUBAO_SPEECH_*）
#   3) 味觉评审 judge    = Qwen via Bailian `bl`（BAILIAN_JUDGE_MODEL，默认 qwen-flash）
# ⚠ 创作模型(author) 与评审模型(judge) 建议用【不同】模型 —— 跨模型评审才可信；同模型自评会自我偏袒。

# ---- 1) Ark / Doubao LLM — 创作 / 选窗（可自选：换 ARK_ENDPOINT_ID 指向你要的模型）-------------
ARK_API_KEY=                                    # Ark inference API key
ARK_ENDPOINT_ID=                                # ep-...  指向你选的创作模型（默认 Doubao-Seed-2.0-lite）
ARK_BASE_URL=                                   # e.g. https://ark.cn-beijing.volces.com/api/v3

# ---- 2) Doubao / Volcengine Speech ASR — 语音转写 (producer-side, OPTIONAL) ---------------------
# 火山引擎 → 语音技术 → 录音文件识别大模型 (same Volc account as Ark; has a free tier).
# WITHOUT these, the Studio "upload a video" pipeline falls back to a bundled sample transcript;
# the rest of the chain (window-LLM / CAB / publish) stays fully live.
DOUBAO_SPEECH_API_KEY=                          # speech Access Token  (-> X-Api-Key)
DOUBAO_SPEECH_UID=                              # speech App ID        (-> user.uid)

# ---- 3) Judge（味觉评审 critic）— Qwen via Bailian `bl` CLI（bl 自带登录）----------------------
# 可自选评审模型；越快越省时（人审 gate 兜底最终判别力）。务必与创作模型用不同模型（见上 ⚠）。
BAILIAN_JUDGE_MODEL=qwen-flash                  # qwen-flash(快) | qwen-turbo | qwen3.6-plus(更稳)

# ---- Media (optional) --------------------------------------------------------------------------
# 可选：外部媒体地址。不配则用本地 tmp 素材 (tmp/视频素材/<剧名>/第N集.mp4)。
DEADMAN_MEDIA_BASE_URL=                         # external media base for the public API

# ---- Runtime options (optional) ----------------------------------------------------------------
# DEADMAN_JUDGMENT_ENGINE=cab_runtime           # cab_runtime (formal, default) | demo_deterministic
# HOST=127.0.0.1                                # loopback by default; set 0.0.0.0 for 局域网访问
# PORT=7861
