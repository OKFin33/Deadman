# 看剧搭子 (Deadman) — environment template.
# Copy to .env and fill in. ALL credentials are environment-only and producer-side
# (used only when the team authors content); never commit real values. The viewer app
# (Stage) needs NO keys — it serves already-reviewed packs.

# ---- Ark / Doubao LLM — CAB authoring + window selection (competition-provided) -----------
ARK_API_KEY=                                    # your Ark inference API key
ARK_ENDPOINT_ID=                                # ep-...  (Doubao-Seed-2.0-lite endpoint)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ---- Doubao / Volcengine Speech ASR — 录音文件识别大模型 (producer-side, OPTIONAL) ---------
# Activate 火山引擎 → 语音技术 → 录音文件识别大模型 (same Volc account as Ark; has a free tier),
# create an app, then set the App ID + Access Token below.
# WITHOUT these, the Studio "upload a video" pipeline gracefully falls back to a bundled sample
# transcript — the rest of the chain (window-LLM / CAB / publish) stays fully live.
DOUBAO_SPEECH_API_KEY=                          # speech Access Token  (-> X-Api-Key)
DOUBAO_SPEECH_UID=                              # speech App ID        (-> user.uid)

# ---- Runtime options (optional) ----------------------------------------------------------
# DEADMAN_JUDGMENT_ENGINE=cab_runtime           # cab_runtime (formal, default) | demo_deterministic
# DEADMAN_MEDIA_BASE_URL=                       # external media base for public API (else local tmp)
# HOST=127.0.0.1                                # loopback by default; set 0.0.0.0 for 本地网络访问
#                                               #   (部署方式2: Local Server, 局域网内访问)
# PORT=7861
